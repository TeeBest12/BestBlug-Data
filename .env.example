# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MongoDB Connection String (Production Database)
MONGODB_URI="mongodb+srv://<username>:<password>@cluster0.mongodb.net/vtu_db"

# Primary Gateway - VTpass Credentials
VTPASS_API_KEY=""
VTPASS_SECRET_KEY=""
VTPASS_LIVE_MODE="false" # Set to "true" when moving to production/live

# Secondary Gateway - Clubkonnect Credentials
CLUBKONNECT_USER_ID=""
CLUBKONNECT_API_KEY=""

# Optional Flutterwave Gateway Credentials
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY="" # Usually starts with FLWPUBK_
FLUTTERWAVE_SECRET_KEY=""             # Usually starts with FLWSECK_
FLUTTERWAVE_ENCRYPTION_KEY=""         # Your Flutterwave Encryption Key
FLUTTERWAVE_CLIENT_ID=""              # Sometimes referred to as Client ID or Public Key
FLUTTERWAVE_CLIENT_SECRET=""          # Sometimes referred to as Client Secret or Secret Key

